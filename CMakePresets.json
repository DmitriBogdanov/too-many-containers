{
    "version": 3,
    
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
    
    "configurePresets": [
        {
            "name": "base",
            "description": "Common configuration variables.",
            "hidden": true,
            "binaryDir": "build/",
            "cacheVariables": {
                "TMC_COMPILE_FEATURES": "cxx_std_23"
            }
        },
        {
            "name": "gcc",
            "description": "GCC configuration variables.",
            "inherits": [ "base" ],
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "g++",
                "TMC_TEST_COMPILER_FLAGS": "-O0;-g3;-Wall;-Wextra;-Wpedantic;-Werror;-fsanitize=address,undefined;-fno-sanitize-recover=all",
                "TMC_TEST_LINKER_FLAGS": "-fsanitize=address,undefined"
            }
        },
        {
            "name": "clang",
            "description": "Clang configuration variables.",
            "inherits": [ "base" ],
            "cacheVariables": {
                "CMAKE_CXX_COMPILER": "clang++",
                "TMC_TEST_COMPILER_FLAGS": "-stdlib=libc++;-O0;-g3;-Wall;-Wextra;-Wpedantic;-Werror;-fsanitize=address,undefined;-fno-sanitize-recover=all",
                "TMC_TEST_LINKER_FLAGS": "-stdlib=libc++;-fsanitize=address,undefined"
            }
        },
        {
            "name": "msvc",
            "description": "MSVC configuration variables.",
            "inherits": [ "base" ],
            "cacheVariables": {
                "CMAKE_CXX_FLAGS_DEBUG": "",
                "CMAKE_CXX_FLAGS_RELEASE": "",
                "TMC_TEST_COMPILER_FLAGS": "/W4;/sdl;/WX;/DEBUG;/Zi;/RTC1;/permissive-;/Zc:preprocessor",
                "TMC_TEST_LINKER_FLAGS": ""
            }
        }
    ],
    
    "buildPresets": [
        {
            "name": "base",
            "description": "Common build variables.",
            "hidden": true,
            "jobs": 6
        },
        { "name": "gcc"      , "configurePreset": "gcc"      , "inherits": [ "base" ] },
        { "name": "clang"    , "configurePreset": "clang"    , "inherits": [ "base" ] },
        { "name": "msvc"     , "configurePreset": "msvc"     , "inherits": [ "base" ] }
    ],
    
    "testPresets": [
        {
            "name": "base",
            "description": "CTest arguments",
            "hidden": true,
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "timeout": 60
            }
        },
        { "name": "gcc"      , "configurePreset": "gcc"      , "inherits": [ "base" ] },
        { "name": "clang"    , "configurePreset": "clang"    , "inherits": [ "base" ] },
        { "name": "msvc"     , "configurePreset": "msvc"     , "inherits": [ "base" ] }
    ]
}
